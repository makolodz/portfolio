---

import '../styles/global.css';
import Header from '../components/header.astro'

---


<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>Maxime Kolodziejczyk</title>
	</head>
	<body>
		<div id="smooth-wrapper">
			<div id="smooth-content" class="snap">
				<Header/>
				<slot/>
			</div>
		</div>
	</body>
</html>

<style>

html,body {
	margin: 0;
	background-attachment: fixed;
	background-size: cover;
	background-image: 
		linear-gradient(
			var(--base-foreground),
			rgba(0, 0, 0, 0),
			rgba(0, 0, 0, 0),
			rgba(0, 0, 0, 0),
			rgba(0, 0, 0, 0),
			rgba(0, 0, 0, 0),
			var(--base-foreground)
		),
		url("/src/assets/images/Tolstoï_labourant.jpg");
}

a {
	display: inline-block;
	width: fit-content;
	height: fit-content;
	padding: 8px 32px;
	border-radius: 60px;
	background-color: var(--muted-background);
	border: 2px solid var(--base-foreground);
	font-size: 1.5rem;
	text-decoration: none;
	color: var(--based-foreground);
}

</style>
